# ---- Secrets / configuration locale ----------------------------------------
.env
.env.*
!.env.example
firebase-service-account.json
*.key
*.pem

# ---- Base de données -------------------------------------------------------
*.sqlite3
*.db
db.sqlite3

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ---- Environnements virtuels ----------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---- Django ----------------------------------------------------------------
media/
staticfiles/
images/
*.log

# ---- Outils / caches -------------------------------------------------------
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache/
.pytest_cache/

# ---- Éditeurs / OS ---------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs applicatifs ------------------------------------------------------
logs/
*.log
