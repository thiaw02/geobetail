# ============================================================================
# GeoBétail - Exemple de configuration
# Copier ce fichier en `.env` puis adapter les valeurs.
# Ne JAMAIS commiter le vrai `.env` (il est ignoré par git).
# ============================================================================

# ---- Sécurité --------------------------------------------------------------
# Générer une nouvelle clé avec :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# (éviter les caractères '$' qui perturbent l'interpolation docker-compose)
SECRET_KEY=change-me-generate-a-random-key
DEBUG=False

# ---- Base de données -------------------------------------------------------
# DB_ENGINE : postgres (Docker / prod) ou sqlite3 (dev local sans PostgreSQL)
DB_ENGINE=postgres
DB_NAME=geobetail
DB_USER=geobetail
DB_PASSWORD=change-me-strong-password
# Dans Docker, l'hôte est le nom du service : "db". En local, "localhost".
DB_HOST=db
DB_PORT=5432

# ---- Médias (volume Docker) ------------------------------------------------
MEDIA_ROOT=/app/data/media

# ---- Firebase (optionnel, désactivé par défaut) ----------------------------
# FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json
# FIREBASE_DB_URL=https://<projet>-default-rtdb.firebaseio.com
